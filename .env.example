SEO_ANALYSIS_PORT=4317
SEO_ANALYSIS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://seo-analysis-two.vercel.app

# Optional. If omitted, the local server tries to find client_secret_*.json in the project root.
GOOGLE_OAUTH_CLIENT_SECRET_FILE=client_secret_your-client.apps.googleusercontent.com.json

# Optional. PageSpeed Insights can be called without a key, but a key is recommended for regular use.
PAGESPEED_API_KEY=
